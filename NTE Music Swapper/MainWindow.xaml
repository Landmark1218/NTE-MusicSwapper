<Window x:Class="NtePakTool.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="NTE Music Swapper - Compact Edition" Height="520" Width="720"
        WindowStartupLocation="CenterScreen" Background="#1E1E1E"
        AllowDrop="True"
        Closing="Window_Closing">

    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#007ACC"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="8,3"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#0098FF"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#2D2D2D"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#555"/>
            <Setter Property="Padding" Value="2"/>
        </Style>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#CCCCCC"/>
        </Style>
    </Window.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="70"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="NTE Music Swapper" Foreground="White" FontSize="18"
                   FontWeight="Bold" HorizontalAlignment="Center"/>

        <!-- 検索バー -->
        <Grid Grid.Row="1" Margin="0,8,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Search (.wem):" Foreground="White" VerticalAlignment="Center" Margin="0,0,8,0" FontSize="11"/>
            <TextBox x:Name="TxtSearch" Grid.Column="1" Height="22" FontSize="11" TextChanged="TxtSearch_TextChanged"/>
        </Grid>

        <!-- タブコントロール -->
        <TabControl Grid.Row="2" Background="Transparent" BorderThickness="0" Margin="0,8">
            <TabControl.Resources>
                <Style TargetType="TabItem">
                    <Setter Property="Background" Value="#333"/>
                    <Setter Property="Foreground" Value="#00FF41"/>
                    <Setter Property="Margin" Value="0,0,2,0"/>
                    <Setter Property="Padding" Value="10,5"/>
                    <Setter Property="FontSize" Value="11"/>
                    <Style.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="#007ACC"/>
                            <Setter Property="Foreground" Value="#00FF41"/>
                            <!-- ヘッダ文字色を緑に統一して視認性を確保 -->
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </TabControl.Resources>

            <TabItem Header="Featured (UI)">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <ItemsControl x:Name="UiListControl">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="4" Padding="6" Background="#141414" BorderThickness="2" CornerRadius="5" Width="135">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="BorderBrush" Value="#333"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                    <Setter Property="BorderBrush" Value="#00FF41"/>
                                                    <Setter Property="Background" Value="#1A2A1A"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <StackPanel>
                                        <Button Background="Transparent" BorderThickness="0" Click="Jacket_Click" Cursor="Hand" Padding="0">
                                            <Image Source="{Binding ImagePath}" Width="115" Height="115" Stretch="UniformToFill"/>
                                        </Button>
                                        <TextBlock Text="{Binding DisplayName}" Foreground="White" FontWeight="Bold" FontSize="10"
                                                   TextAlignment="Center" Margin="0,4,0,0" TextWrapping="Wrap" Height="28"/>
                                        <Button Content="Browse" Click="BrowseAudio_Click" Margin="0,4,0,0" Height="20" Background="#444" FontSize="9"/>
                                        <TextBlock Text="{Binding SourceAudioPath}" Foreground="#888" FontSize="8" 
                                                   TextTrimming="CharacterEllipsis" Margin="0,2,0,0" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="All Files (List)">
                <Border BorderBrush="#333" BorderThickness="1">
                    <ListBox x:Name="FileList" Background="#141414" Foreground="#00FF41" FontSize="10"
                             BorderThickness="0" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <DockPanel Margin="1">
                                    <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                              VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <Button Content="Set" Click="BrowseAudio_Click"
                                            DockPanel.Dock="Right" Width="45" Height="18"
                                            FontSize="8" Background="#444"/>
                                    <StackPanel>
                                        <TextBlock Text="{Binding RelativePath}" Foreground="#00FF41" FontWeight="Bold"/>
                                        <TextBlock Text="{Binding SourceAudioPath}" Foreground="#888"
                                                   FontSize="8" TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>
                                </DockPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Border>
            </TabItem>
        </TabControl>

        <Border Grid.Row="3" Background="#0A0A0A" CornerRadius="3"
                BorderBrush="#333" BorderThickness="1" Margin="0,2,0,2">
            <ScrollViewer x:Name="LogScroller">
                <TextBlock x:Name="TxtLog" Foreground="#888" FontFamily="Consolas"
                           FontSize="9" Margin="5" TextWrapping="Wrap"/>
            </ScrollViewer>
        </Border>

        <Grid Grid.Row="4" Margin="0,6,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Button Grid.ColumnSpan="2" Content="REFRESH DATA" Click="RefreshList_Click"
                    Height="22" Background="#444" Margin="0,0,0,4" FontSize="10"/>

            <Button x:Name="BtnBuildMod" Grid.Row="1" Grid.Column="0" Content="BUILD MOD"
                    Click="BuildPak_Click" Height="40" FontSize="13"
                    Background="#CE9178" Foreground="Black" Margin="0,0,4,0"/>

            <StackPanel Grid.Row="1" Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Center">
                <CheckBox x:Name="ChkSaveMod" Content="Auto-Save &amp; Apply MOD"
                          Foreground="White" HorizontalAlignment="Center"
                          FontSize="11" Checked="ChkSaveMod_Changed" Unchecked="ChkSaveMod_Changed"/>
                <CheckBox x:Name="ChkUseYouTube" Content="Use YouTube Link"
                          Foreground="#FF6B6B" HorizontalAlignment="Center"
                          FontSize="11" Margin="0,5,0,0"
                          Checked="ChkUseYouTube_Changed" Unchecked="ChkUseYouTube_Changed"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>